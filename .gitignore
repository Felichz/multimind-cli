# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node
node_modules/
*.log
.bun

# Build
dist/
build/

# Test artifacts
.test-runs/
.multimind/
evals/runs/

# Per-run report files written by the eval runner (auto-generated).
# We ship the canonical `latest.md` (manual summary) and `.gitkeep`
# (so the directory exists). The re-include below must come after
# the matching pattern above.
evals/reports/*
!evals/reports/.gitkeep
!evals/reports/latest.md

# Runtime artifacts: the evolution engine writes per-run session data
# (debug-store, synthetic tests, empirical contract files) to a hidden
# `.opencode/subconscious/` next to the working directory. Not part of
# the harness, not for the public repo.
.opencode/

# User refinements: prompts-extensions/ is where each user (or project)
# stores their personal worker refinements. The core harness ships with
# just the prompts/ directory. Users who want to customize copy the
# example extensions and let the pipeline combine core + extensions at
# runtime.
src/prompts-extensions/*
!src/prompts-extensions/.gitkeep

# Auto-generated synthetic test files produced by the evolution engine.
# Not for the repo. If you want to keep a specific synthetic test, copy
# it into a regular test file.
src/prompts/AUTO-GEN-*.json
tests/fail_first_synthetic_eval*.json
