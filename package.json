{
  "name": "multimind-cli",
  "version": "0.1.0",
  "description": "Background thinking pipeline as a command. Provider-agnostic, stateless, designed to be driven by any LLM-powered tool.",
  "type": "module",
  "bin": {
    "multimind": "./bin/multimind.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pipeline": "./src/pipeline/run.ts",
    "./consolidator": "./src/consolidator.ts",
    "./engines": "./src/engines/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "ci": "bun run typecheck && bun run lint && bun run test",
    "evals": "bun run evals/runner.ts"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
